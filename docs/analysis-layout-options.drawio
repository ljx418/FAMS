        <mxCell id="ov-title" value="FAMS Analysis Page Layout Options" style="text;html=1;fontSize=26;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#F8FAFC;" vertex="1" parent="1">
          <mxGeometry x="430" y="20" width="740" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ov-subtitle" value="Four layout directions for the Analysis page. Choose one before I refactor the page structure." style="text;html=1;fontSize=13;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#94A3B8;" vertex="1" parent="1">
          <mxGeometry x="300" y="62" width="1000" height="26" as="geometry"/>
        </mxCell>

        <mxCell id="ov-a" value="Option A&#xa;Command Center&#xa;&#xa;Top: conclusion / risk / pending&#xa;Left: key suggestions + full list&#xa;Right: execution + recent tasks&#xa;Bottom: folded detail blocks&#xa;&#xa;Best fit for current product" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A5F;strokeColor=#60A5FA;fontSize=16;fontStyle=1;arcSize=8;fontColor=#F8FAFC;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="320" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="ov-b" value="Option B&#xa;Portfolio Overview&#xa;&#xa;Top: portfolio / pnl / allocation&#xa;Middle: advice summary + risk summary&#xa;Bottom tabs: suggestions / research / tasks / backtest&#xa;&#xa;More traditional wealth dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1F4D3A;strokeColor=#34D399;fontSize=16;fontStyle=1;arcSize=8;fontColor=#F8FAFC;" vertex="1" parent="1">
          <mxGeometry x="450" y="140" width="320" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="ov-c" value="Option C&#xa;Inbox Workflow&#xa;&#xa;Left rail: filters&#xa;Middle: suggestion list&#xa;Right: selected suggestion detail&#xa;&#xa;Fastest for processing many suggestions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4A3A18;strokeColor=#FBBF24;fontSize=16;fontStyle=1;arcSize=8;fontColor=#F8FAFC;" vertex="1" parent="1">
          <mxGeometry x="820" y="140" width="320" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="ov-d" value="Option D&#xa;Dual Mode&#xa;&#xa;Top mode switch: Overview / Execute&#xa;Overview mode emphasizes portfolio&#xa;Execute mode emphasizes suggestions&#xa;&#xa;Most flexible, also most complex" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#34254A;strokeColor=#A78BFA;fontSize=16;fontStyle=1;arcSize=8;fontColor=#F8FAFC;" vertex="1" parent="1">
          <mxGeometry x="1190" y="140" width="320" height="260" as="geometry"/>
        </mxCell>

        <mxCell id="ov-rank-title" value="Recommended Order" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#F8FAFC;" vertex="1" parent="1">
          <mxGeometry x="80" y="450" width="260" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ov-rank" value="1. Option A - strongest fit for your current advice-to-trade workflow&#xa;2. Option C - best if suggestion volume will keep growing&#xa;3. Option D - balanced, but more implementation cost&#xa;4. Option B - safest, but weaker for action handling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1F2937;strokeColor=#64748B;fontSize=15;arcSize=8;fontColor=#F8FAFC;" vertex="1" parent="1">
          <mxGeometry x="80" y="490" width="650" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="ov-note" value="Current page pain point: one screen is carrying too many roles at once - overview, research, suggestions, execution, task chain, and reliability." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4A2428;strokeColor=#F87171;fontSize=15;arcSize=8;fontColor=#F8FAFC;" vertex="1" parent="1">
          <mxGeometry x="780" y="490" width="730" height="160" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

