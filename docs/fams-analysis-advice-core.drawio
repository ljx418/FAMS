  <diagram id="fivd-development-plan" name="04 开发与验收计划">
    <mxGraphModel dx="1768" dy="1053" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p4-title" parent="1" style="text;html=1;fontSize=30;align=center;verticalAlign=middle;strokeColor=#2D7600;fillColor=#60a917;fontColor=#ffffff;fontStyle=1;" value="FIVD-R 开发阶段与节点验收计划" vertex="1">
          <mxGeometry height="50" width="1080" x="360" y="30" as="geometry" />
        </mxCell>
        <mxCell id="p4-principle" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#6B7280;arcSize=8;fontColor=#111827;fontStyle=1;fontSize=16;spacing=12;" value="总原则&lt;br&gt;先结构化，再解释&lt;br&gt;先可追溯，再调优&lt;br&gt;先回放验证，再上线参数&lt;br&gt;先研究建议，再考虑交易动作" vertex="1">
          <mxGeometry height="170" width="350" x="70" y="130" as="geometry" />
        </mxCell>
        <mxCell id="p4-codex" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#4F81BD;arcSize=8;fontColor=#111827;fontStyle=1;fontSize=16;spacing=12;" value="执行入口&lt;br&gt;04_Codex_Terminal_Prompt.txt&lt;br&gt;可复制到 Codex CLI / 终端 Agent&lt;br&gt;第一步只做 implementation map&lt;br&gt;确认后 Phase 0 → Phase 1" vertex="1">
          <mxGeometry height="180" width="350" x="70" y="350" as="geometry" />
        </mxCell>
        <mxCell id="p4-p0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4CC;strokeColor=#D6A700;arcSize=8;fontColor=#111827;fontStyle=1;fontSize=15;spacing=10;" value="Phase 0：Schema 与类型冻结&lt;br&gt;InvestmentValuationInput / Output&lt;br&gt;EvidenceGateResult&lt;br&gt;ExpectedReturnDistribution&lt;br&gt;TradingDiscipline&lt;br&gt;验收：TS 编译、枚举测试、implementation map" vertex="1">
          <mxGeometry height="190" width="370" x="520" y="130" as="geometry" />
        </mxCell>
        <mxCell id="p4-p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DFF3E3;strokeColor=#4F9D69;arcSize=8;fontColor=#111827;fontStyle=1;fontSize=15;spacing=10;" value="Phase 1：价值评估模型 MVP&lt;br&gt;EvidenceGateService&lt;br&gt;Stock / ETF / Gold / Cash 模型&lt;br&gt;PositionAdviceImpactAdapter&lt;br&gt;验收：资产分流、分数证据、validation failed 阻断 ADD" vertex="1">
          <mxGeometry height="190" width="370" x="970" y="130" as="geometry" />
        </mxCell>
        <mxCell id="p4-p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DFF3E3;strokeColor=#4F9D69;arcSize=8;fontColor=#111827;fontStyle=1;fontSize=15;spacing=10;" value="Phase 2：预计盈亏概率分布&lt;br&gt;20d / 60d MVP&lt;br&gt;p05 / p25 / p50 / p75 / p95&lt;br&gt;gain/loss/stop/take probability&lt;br&gt;验收：样本不足 confidence=insufficient" vertex="1">
          <mxGeometry height="190" width="320" x="1420" y="130" as="geometry" />
        </mxCell>
        <mxCell id="p4-p3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DFF3E3;strokeColor=#4F9D69;arcSize=8;fontColor=#111827;fontStyle=1;fontSize=15;spacing=10;" value="Phase 3：交易纪律模型&lt;br&gt;core：最大回撤预算&lt;br&gt;satellite：有效期、止损、止盈、失效条件&lt;br&gt;cash：no_action&lt;br&gt;验收：targetWeightMultiplier 可被消费" vertex="1">
          <mxGeometry height="190" width="370" x="520" y="430" as="geometry" />
        </mxCell>
        <mxCell id="p4-p4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#8B5CF6;arcSize=8;fontColor=#111827;fontStyle=1;fontSize=15;spacing=10;" value="Phase 4：分析建议前端卡片&lt;br&gt;顶部结论、评分、概率分布&lt;br&gt;交易纪律、证据缺口、AI 解释&lt;br&gt;验收：formalTradeActionAllowed 可见，AI 不新增交易结论" vertex="1">
          <mxGeometry height="190" width="370" x="970" y="430" as="geometry" />
        </mxCell>
        <mxCell id="p4-p5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4CC;strokeColor=#D6A700;arcSize=8;fontColor=#111827;fontStyle=1;fontSize=15;spacing=10;" value="Phase 5：Advice Replay 基础版&lt;br&gt;3m / 2m / 1m 固定起点&lt;br&gt;每周复盘，T+1 模拟成交&lt;br&gt;FAMS vs BuyHold vs Benchmark&lt;br&gt;验收：无未来函数、交易可追溯 decision_id" vertex="1">
          <mxGeometry height="200" width="320" x="1420" y="430" as="geometry" />
        </mxCell>
        <mxCell id="p4-p6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4CC;strokeColor=#D6A700;arcSize=8;fontColor=#111827;fontStyle=1;fontSize=15;spacing=10;" value="Phase 6：动作质量与概率校准&lt;br&gt;ADD / REDUCE / HOLD / OBSERVE 成效&lt;br&gt;p05-p95 覆盖率&lt;br&gt;概率校准与过度乐观 warning&lt;br&gt;验收：报告可展示" vertex="1">
          <mxGeometry height="190" width="370" x="520" y="750" as="geometry" />
        </mxCell>
        <mxCell id="p4-p7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;arcSize=8;fontColor=#111827;fontStyle=1;fontSize=15;spacing=10;" value="Phase 7：人工干预与模型调优&lt;br&gt;append-only intervention_events&lt;br&gt;Champion / Challenger&lt;br&gt;Replay validation 后人工 promote&lt;br&gt;验收：未验证不能 promote" vertex="1">
          <mxGeometry height="190" width="370" x="970" y="750" as="geometry" />
        </mxCell>
        <mxCell id="p4-hardgate" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;arcSize=8;fontColor=#111827;fontStyle=1;fontSize=15;spacing=10;" value="上线前硬门禁&lt;br&gt;无 evidenceRefs 不上线&lt;br&gt;Validation failed 不允许 formal ADD&lt;br&gt;Replay 不得有未来函数&lt;br&gt;概率样本不足不得 high confidence&lt;br&gt;Challenger 未验证不得 promote" vertex="1">
          <mxGeometry height="210" width="320" x="1420" y="750" as="geometry" />
