  <diagram id="06 开发及验收计划" name="06 开发及验收计划">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="06-title" value="开发及验收计划：UX-1 到 UX-6，完成后普通用户可理解，专业审计不丢失" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#1f2937;fontColor=#ffffff;fontStyle=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1840" height="70" as="geometry" />
        </mxCell>
        <mxCell id="06-ux1" value="UX-1 全局信息架构&#xa;实体：AppLayout.tsx / Dashboard.tsx&#xa;效果：每页说明本页能做什么、适合谁、下一步。&#xa;验收：首屏不是复杂表格。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="60" y="135" width="560" height="190" as="geometry" />
        </mxCell>
        <mxCell id="06-ux2" value="UX-2 普通/专业模式&#xa;实体：ExperienceModeToggle.tsx / PlainLanguageHelp.tsx&#xa;效果：普通模式默认，专业模式保留完整审计。&#xa;验收：切换不改变后端结果。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="680" y="135" width="560" height="190" as="geometry" />
        </mxCell>
        <mxCell id="06-ux3" value="UX-3 红利低波结论卡&#xa;实体：DividendLowVolDecisionCard.tsx&#xa;效果：可研究/仅观察/数据不足/风险剔除 + 3 条原因。&#xa;验收：普通用户不需要理解综合分。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1300" y="135" width="560" height="190" as="geometry" />
        </mxCell>
        <mxCell id="06-ux4" value="UX-4 回测摘要&#xa;实体：PortfolioBacktestSummaryCard.tsx / StrategyComparisonExplainer.tsx&#xa;效果：收益、回撤、可信度、阻断摘要。&#xa;验收：曲线与解释一致。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="60" y="390" width="560" height="190" as="geometry" />
        </mxCell>
        <mxCell id="06-ux5" value="UX-5 审计人类可读&#xa;实体：Operations.tsx / acceptance-report.html&#xa;效果：任务做了什么、产物在哪里、能否用于交易。&#xa;验收：报告不只服务开发者。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="680" y="390" width="560" height="190" as="geometry" />
        </mxCell>
        <mxCell id="06-ux6" value="UX-6 视觉降噪与可访问性&#xa;实体：index.css / 页面公共卡片标签表格&#xa;效果：统一状态色、隐藏低频列、无文字溢出。&#xa;验收：桌面/平板/移动截图通过。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1300" y="390" width="560" height="190" as="geometry" />
        </mxCell>
        <mxCell id="06-test" value="文档阶段验收&#xa;node docs/read-drawio.mjs docs/target-architecture-gap.drawio &gt; docs/read-drawio-output.txt&#xa;rg UX 状态和实体绑定&#xa;rg 交易误放行字符串，期望无命中&#xa;git diff --check -- docs" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#999999;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="1800" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="07 里程碑与出门条件" name="07 里程碑与出门条件">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="07-title" value="里程碑、出门条件与审计路径：UX 阶段只提升理解路径，不释放交易动作" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#1f2937;fontColor=#ffffff;fontStyle=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1840" height="70" as="geometry" />
        </mxCell>
        <mxCell id="07-m1" value="M1 文档出门&#xa;PRD、计划、目标架构、drawio、审计报告一致。&#xa;drawioPageCount=8 且 &lt;=8。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="70" y="140" width="390" height="190" as="geometry" />
        </mxCell>
        <mxCell id="07-m2" value="M2 UX 架构出门&#xa;普通模式、专业模式、结论卡、摘要卡、术语解释均绑定真实实体。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="520" y="140" width="390" height="190" as="geometry" />
        </mxCell>
        <mxCell id="07-m3" value="M3 UX 实现出门&#xa;ordinaryUserExperienceReady=true&#xa;frontendComplexityReduced=true&#xa;桌面/平板/移动截图通过。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="970" y="140" width="390" height="190" as="geometry" />
        </mxCell>
        <mxCell id="07-m4" value="M4 正式交易 Release 出门&#xa;正式 provider、可信 benchmark、formal validation、人工签核全部通过后另行评审。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#f4cccc;strokeColor=#cc0000;fontColor=#990000;" vertex="1" parent="1">
          <mxGeometry x="1420" y="140" width="390" height="190" as="geometry" />
        </mxCell>
        <mxCell id="07-can" value="当前可声明&#xa;researchReady=true&#xa;portfolioBacktestFormalReviewReady=true&#xa;manualTradePlanDraftReviewReady=true&#xa;userExperienceOptimizationPlanReady=true" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="70" y="410" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-cannot" value="当前不能声明&#xa;formalTradingUnlocked 不得为 true&#xa;autoTradeUnlocked 不得为 true&#xa;orderCreateAllowed 不得为 true&#xa;canCreateOrder 不得为 true" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#f4cccc;strokeColor=#cc0000;fontColor=#990000;" vertex="1" parent="1">
          <mxGeometry x="520" y="410" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-audit" value="必须审计路径&#xa;docs/USER_EXPERIENCE_OPTIMIZATION_PLAN.md&#xa;docs/USER_EXPERIENCE_OPTIMIZATION_DOC_AUDIT.md&#xa;docs/target-architecture-gap.drawio&#xa;docs/read-drawio-output.txt&#xa;acceptance-report.html" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#999999;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="970" y="410" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-risk" value="风险控制&#xa;UX 简化不得隐藏 dataTrustGrade=INSUFFICIENT、calculationAudit=deterministic_replay_only、validation blocker、正式交易锁定。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1420" y="410" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-exit" value="最终出门条件&#xa;人类能从文档和图中快速理解目标体验、目标架构、当前差异、开发计划、里程碑、验收门槛与禁止动作。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="70" y="710" width="1740" height="130" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="08 ChatBox 与 AgentCore 业务入口" name="08 ChatBox 与 AgentCore 业务入口">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="08-title" value="ChatBox 与 PI AgentCore：全局业务入口，只编排研究、观察和草案，不执行交易" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#1f2937;fontColor=#ffffff;fontStyle=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1840" height="70" as="geometry" />
        </mxCell>
        <mxCell id="08-legend" value="颜色：灰色=已实现基础；黄色=需修改补齐；橘黄=待新增目标；红色=硬边界；蓝色=用户路径；绿色=目标体验输出。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=middle;fillColor=#ffffff;strokeColor=#999999;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="1800" height="55" as="geometry" />
        </mxCell>
        <mxCell id="08-user" value="用户自然语言入口&#xa;示例：&#xa;帮我看红利低波前三只候选&#xa;刷新红利低波扫描&#xa;这个组合能不能交易&#xa;最近任务有什么结果" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="08-ui" value="前端已实现基础&#xa;FamsChatBox.tsx&#xa;AppLayout.tsx 全局入口&#xa;快捷问题与行动卡&#xa;研究模式边界提示" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#e5e7eb;strokeColor=#9ca3af;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="400" y="220" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="08-api" value="后端已实现基础&#xa;backend/src/routes/chat.ts&#xa;famsChatService&#xa;piAgentCoreAdapter&#xa;verify-chat-agent-core.ts&#xa;白名单工具与二次确认" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#e5e7eb;strokeColor=#9ca3af;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="760" y="220" width="320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="08-tools" value="可编排业务能力&#xa;红利低波候选查询&#xa;组合与任务状态查询&#xa;跳转 DividendLowVol / Backtest / Operations&#xa;需确认的扫描或草案 Operation" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1140" y="220" width="330" height="170" as="geometry" />
        </mxCell>
        <mxCell id="08-outcome" value="目标体验输出&#xa;用户能用一句话找到候选、组合、任务和阻断原因。&#xa;系统返回解释、证据入口、确认卡和页面跳转。&#xa;不需要先理解所有菜单和指标。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1530" y="220" width="330" height="170" as="geometry" />
        </mxCell>
        <mxCell id="08-gap1" value="需修改：会话与事件&#xa;ChatSession / ChatMessage 持久化缺失&#xa;流式事件缺失&#xa;Operation 进度没有实时回写到对话" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="400" y="470" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="08-gap2" value="需修改：AgentCore 集成深度&#xa;piAgentCoreRuntimeIntegrated=true&#xa;piLlmAgentLoopEnabled=false&#xa;当前仍使用 deterministic planner fallback&#xa;工具覆盖不完整" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="760" y="470" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="08-target1" value="待新增：完整 ChatBox 目标架构&#xa;ChatSession 审计存储&#xa;PI LLM agent loop&#xa;SSE 或 WebSocket 流式事件&#xa;全业务 tool registry&#xa;chatbox_agentcore_audit.json" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1140" y="470" width="330" height="160" as="geometry" />
        </mxCell>
        <mxCell id="08-boundary" value="硬边界&#xa;不得调用非白名单工具&#xa;不得直接访问 shell / 文件系统 / 不受控网络&#xa;不得创建订单&#xa;不得输出正式 ADD / REDUCE / ORDER_CREATE / AUTO_TRADE&#xa;任何副作用动作必须二次确认并落审计" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#f4cccc;strokeColor=#cc0000;fontColor=#990000;" vertex="1" parent="1">
          <mxGeometry x="1530" y="470" width="330" height="160" as="geometry" />
        </mxCell>
        <mxCell id="08-accept" value="开发及验收计划&#xa;CA-1 文档与状态词典：ChatBox v1 与完整集成边界一致。&#xa;CA-2 会话持久化：刷新后可追溯历史对话和工具调用。&#xa;CA-3 PI Agent loop：LLM 只能在白名单工具和 gate 内编排。&#xa;CA-4 流式任务：Operation 进度、artifactRefs、阻断原因回写对话。&#xa;CA-5 全路径验收：红利低波、组合回测、任务中心、人工草案和交易阻断均可用自然语言触达。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#999999;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="60" y="700" width="1800" height="170" as="geometry" />
        </mxCell>
        <mxCell id="08-e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6b7280;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="08-user" target="08-ui">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="08-e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6b7280;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="08-ui" target="08-api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="08-e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6b7280;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="08-api" target="08-tools">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="08-e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6b7280;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="08-tools" target="08-outcome">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="08-e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="08-ui" target="08-gap1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="08-e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="08-api" target="08-gap2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="08-e7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="08-gap2" target="08-target1">
          <mxGeometry relative="1" as="geometry" />
