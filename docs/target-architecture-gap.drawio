        <mxCell id="p5-doc" value="文档验收&#xa;&#xa;drawio 页数 &lt;= 8&#xa;中文书写&#xa;可被 read-drawio 解析&#xa;目标体验 / 架构差异 / 计划 / 里程碑 / 门槛 / 出门条件一致" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=16;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="90" y="170" width="330" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p5-user" value="用户体验验收&#xa;&#xa;能进入红利低波页面并筛选候选&#xa;能进入策略回测页并比较至少 3 条 completed 曲线&#xa;能看懂入选、剔除、priceAudit、benchmark 和缺口&#xa;能生成草案但不能下单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=10;" vertex="1" parent="1">
