  <diagram id="page-fivdr-validation-status" name="6 FIVD-R有效性验证状态">
    <mxGraphModel dx="1920" dy="1080" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p6-title" value="FIVD-R 有效性验证状态：当前是研究验证与交易阻断框架，不是已证明有效的交易模型" style="text;html=1;fontSize=28;fontStyle=1;align=center;strokeColor=none;fillColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="130" y="40" width="1660" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p6-question" value="核心问题&#xa;&#xa;是否完整验证了历史数据和模型有效性？&#xa;&#xa;当前答案：没有达到 formal trading validation。&#xa;已完成研究级证据链与失败诊断，但 OOS / validation evidence 未通过时，只能研究、观察、草案和阻断。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=17;fontStyle=1;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="120" y="150" width="520" height="250" as="geometry" />
        </mxCell>
        <mxCell id="p6-verified" value="已经验证 / 已有产物&#xa;&#xa;全 A 扫描链路&#xa;market bar / feature cache&#xa;providerSuccess / cacheHit / coverage&#xa;策略回测 artifact&#xa;OOS 诊断 artifact&#xa;walk-forward / 参数敏感性 / 分组稳定性产物&#xa;trade gate contract：不误放交易动作" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=16;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="720" y="150" width="460" height="250" as="geometry" />
        </mxCell>
        <mxCell id="p6-not-verified" value="尚未完整验证 / 不能承诺&#xa;&#xa;不能证明模型可稳定赚钱&#xa;不能证明样本外长期稳定&#xa;不能证明所有市场状态有效&#xa;不能把 proxy benchmark 当 formal benchmark&#xa;不能把免费源 freshness 当实时行情保证&#xa;不能输出正式 ADD / REDUCE / AUTO_TRADE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=16;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1260" y="150" width="500" height="250" as="geometry" />
        </mxCell>
        <mxCell id="p6-data-gate" value="历史数据有效性 Gate&#xa;&#xa;1 数据覆盖：全 A / 行业 / 市值 / 流动性覆盖达标&#xa;2 新鲜度：tradeDate、sourceType、freshnessStatus 可审计&#xa;3 价格一致性：priceAudit aligned&#xa;4 交易约束：涨跌停、停牌、ST、退市事实&#xa;5 分红总回报：除权、现金分红、再投资、税费、滑点" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=16;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="500" width="430" height="290" as="geometry" />
        </mxCell>
        <mxCell id="p6-model-gate" value="模型有效性 Gate&#xa;&#xa;1 OOS 正收益且超额收益为正&#xa;2 walk-forward 多窗口通过&#xa;3 参数邻域稳定，不是单点过拟合&#xa;4 行业 / 市场状态 / 流动性分组稳定&#xa;5 足够样本数和交易路径&#xa;6 失败时输出 taxonomy，不调低门槛" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=16;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="745" y="500" width="430" height="290" as="geometry" />
        </mxCell>
        <mxCell id="p6-decision" value="当前系统决策&#xa;&#xa;FIVD-R 可以做：&#xa;事实解释 / 研究排序 / 观察提醒 / 人工计划草案 / 失败归因 / 交易阻断&#xa;&#xa;FIVD-R 不能做：&#xa;证明策略一定有效 / 直接交易建议 / 下单 / 自动交易" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=16;fontStyle=1;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1340" y="500" width="430" height="290" as="geometry" />
        </mxCell>
        <mxCell id="p6-e1" value="证据链" style="endArrow=block;html=1;strokeColor=#64748B;strokeWidth=2;" edge="1" parent="1" source="p6-question" target="p6-verified">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p6-e2" value="边界" style="endArrow=block;html=1;strokeColor=#DC2626;strokeWidth=2;" edge="1" parent="1" source="p6-verified" target="p6-not-verified">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p6-e3" value="先验证数据" style="endArrow=block;html=1;strokeColor=#D17A22;strokeWidth=2;" edge="1" parent="1" source="p6-not-verified" target="p6-data-gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p6-e4" value="再验证模型" style="endArrow=block;html=1;strokeColor=#D17A22;strokeWidth=2;" edge="1" parent="1" source="p6-data-gate" target="p6-model-gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p6-e5" value="决定动作边界" style="endArrow=block;html=1;strokeColor=#DC2626;strokeWidth=2;" edge="1" parent="1" source="p6-model-gate" target="p6-decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page-portfolio-backtest" name="7 组合策略回测目标">
    <mxGraphModel dx="1920" dy="1080" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p7-title" value="组合策略回测本阶段目标：标准组合、真实样本、benchmark、分红总回报逐步补齐；研究用，不自动交易" style="text;html=1;fontSize=27;fontStyle=1;align=center;strokeColor=none;fillColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="120" y="40" width="1680" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p7-user" value="目标用户体验（灰色已实现，继续增强）&#xa;&#xa;进入策略回测页 -> 选择永久组合、全天候、当前持仓、红利低波、自定义或本地真实样本组合&#xa;&#xa;设置区间、初始资金、再平衡、分红模式、费用、滑点和 benchmark&#xa;&#xa;查看多组合曲线、指标表、benchmarkReturn、excessReturn、缺口和非交易提示" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="150" width="430" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p7-current" value="当前已实现（灰色）&#xa;&#xa;Backtest 页面组合模块&#xa;/api/v1/portfolio-backtest/templates&#xa;/api/v1/portfolio-backtest/run&#xa;PortfolioStrategyRegistry / InputBuilder / Engine / BenchmarkService&#xa;3 条本地真实行情 completed 曲线&#xa;local_equal_weight_20 研究 benchmark" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="610" y="150" width="370" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p7-gap" value="当前缺口（黄色需修改）&#xa;&#xa;标准 ETF 代理行情为 0：510300 / 511010 / 511260 / 518880 / 159985&#xa;&#xa;永久组合、全天候仍 insufficient&#xa;&#xa;当前用户 open positions=0，真实持仓组合 insufficient&#xa;&#xa;分红总回报、正式 benchmark、Operation artifact 仍未完成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="150" width="380" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p7-boundary" value="交易边界（红色硬约束）&#xa;&#xa;只允许 RESEARCH / OBSERVE / COMPARE / PLAN_DRAFT&#xa;&#xa;禁止 ADD / REDUCE / ORDER_CREATE / AUTO_TRADE&#xa;&#xa;本地样本组合不是推荐组合&#xa;local_equal_weight_20 是 research proxy&#xa;缺分红或正式 benchmark 时不得 formal validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=15;fontStyle=1;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1510" y="150" width="320" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p7-arch" value="目标架构（橘黄新增/继续建设）&#xa;&#xa;PortfolioBacktestArtifactService&#xa;Operation 化运行与任务中心追踪&#xa;标准 ETF 代理行情接入&#xa;正式/免费 benchmark adapter&#xa;分红事件与除权调整&#xa;price-only / dividend cash / reinvest 三模式&#xa;前端运行态验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="130" y="540" width="430" height="290" as="geometry" />
        </mxCell>
        <mxCell id="p7-flow" value="开发及验收计划（本阶段效果）&#xa;&#xa;PBT-8：补齐 ETF 代理行情，标准组合 completed&#xa;PBT-9：benchmark adapter + 分红总回报，显示分红贡献与超额收益&#xa;PBT-10：Operation + artifactRefs，任务中心可追踪&#xa;&#xa;完成后用户可比较：本地样本 / 永久组合 / 全天候 / 当前持仓 / 红利低波篮子" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="540" width="440" height="290" as="geometry" />
        </mxCell>
        <mxCell id="p7-acceptance" value="验收门槛与出门条件（绿色）&#xa;&#xa;当前已出门：research-grade 多曲线对比 / 3 条真实样本曲线 / benchmark proxy 可见 / 交易动作禁止&#xa;&#xa;下一阶段出门：ETF 代理 >=250 交易日 / 至少 1 个宽基 benchmark / dividendContribution 不恒为 null / Operation artifact 可审计&#xa;&#xa;不能出门：formal trade ready / auto rebalance / auto trade" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;fontSize=15;fontStyle=1;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1340" y="540" width="460" height="290" as="geometry" />
        </mxCell>
        <mxCell id="p7-e1" value="复用" style="endArrow=block;html=1;strokeColor=#64748B;strokeWidth=2;" edge="1" parent="1" source="p7-current" target="p7-arch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7-e2" value="补齐" style="endArrow=block;html=1;strokeColor=#D97706;strokeWidth=2;" edge="1" parent="1" source="p7-gap" target="p7-arch">
