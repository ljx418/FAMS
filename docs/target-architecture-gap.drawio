        <mxCell id="p6-e2" value="真实数据" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p6-ux" target="p6-data">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p6-e3" value="验证" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p6-data" target="p6-val">
