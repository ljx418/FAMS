  <diagram id="p3" name="3 交互式策略回测架构">
    <mxGraphModel dx="1920" dy="1080" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p3-title" value="交互式策略回测目标架构：模板、输入、引擎、benchmark、artifact、前端展示" style="text;html=1;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="120" y="35" width="1680" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p3-templates" value="策略模板层&#xa;&#xa;permanent_portfolio&#xa;all_weather&#xa;current_holdings_buy_and_hold&#xa;dividend_low_vol_basket&#xa;custom_weight_portfolio&#xa;local_real_data_*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="330" height="260" as="geometry" />
        </mxCell>
        <mxCell id="p3-input" value="输入构建层&#xa;&#xa;strategyVersion、assetUniverse、weightPolicy、rebalancePolicy、dividendPolicy、costModel、benchmarkPolicy、evidenceRefs。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="470" y="160" width="340" height="260" as="geometry" />
        </mxCell>
        <mxCell id="p3-data" value="数据与约束层&#xa;&#xa;行情、分红、ETF 代理、benchmark、涨跌停、停牌、ST/退市、freshness、coverage、blockedReasons。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="870" y="160" width="350" height="260" as="geometry" />
        </mxCell>
        <mxCell id="p3-engine" value="组合 replay 引擎&#xa;&#xa;按日净值、收益、回撤、再平衡、费用、滑点、分红现金/再投资、benchmark 对比。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1280" y="160" width="350" height="260" as="geometry" />
        </mxCell>
        <mxCell id="p3-artifact" value="Operation 与 artifact&#xa;&#xa;01 输入定义&#xa;02 数据覆盖&#xa;03 曲线和指标&#xa;04 benchmark&#xa;05 前端路径&#xa;06 trade gate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="560" width="360" height="250" as="geometry" />
        </mxCell>
        <mxCell id="p3-ui" value="前端展示&#xa;&#xa;多曲线图、回撤图、指标表、数据缺口、benchmark 状态、分红贡献、非交易提示。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="780" y="560" width="360" height="250" as="geometry" />
        </mxCell>
        <mxCell id="p3-contract" value="输出契约&#xa;&#xa;每条曲线必须包含 strategyId、dateRange、dataCoverage、evidenceRefs、warnings、blockedReasons、notTradingAdvice。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1260" y="560" width="360" height="250" as="geometry" />
        </mxCell>
        <mxCell id="p3-e1" value="选择" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p3-templates" target="p3-input">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e2" value="构建输入" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p3-input" target="p3-data">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e3" value="回测" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p3-data" target="p3-engine">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e4" value="落盘" style="endArrow=block;html=1;strokeColor=#D17A22;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p3-engine" target="p3-artifact">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e5" value="展示" style="endArrow=block;html=1;strokeColor=#D17A22;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p3-artifact" target="p3-ui">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e6" value="验收" style="endArrow=block;html=1;strokeColor=#DC2626;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p3-ui" target="p3-contract">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
