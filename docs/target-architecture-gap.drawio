  <diagram id="p7" name="7 关键用户路径与审计">
    <mxGraphModel dx="1920" dy="1080" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p7-title" value="关键用户场景：从策略选择到回测比较、草案生成和审计追溯" style="text;html=1;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="120" y="35" width="1680" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p7-path1" value="路径 A：比较策略&#xa;&#xa;策略回测页 -&gt; 选择永久组合/全天候/红利低波/本地样本 -&gt; 设置近 1 年或近 3 年 -&gt; 运行 -&gt; 查看曲线和指标。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="90" y="150" width="420" height="220" as="geometry" />
        </mxCell>
        <mxCell id="p7-path2" value="路径 B：红利低波草案&#xa;&#xa;红利低波页 -&gt; 筛选行业和分数 -&gt; 查看候选详情和观察区间 -&gt; 进入回测比较 -&gt; 生成人工计划草案。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="570" y="150" width="420" height="220" as="geometry" />
        </mxCell>
        <mxCell id="p7-path3" value="路径 C：缺口处理&#xa;&#xa;数据 stale、benchmark proxy、ETF 行情缺失、runtime critical、validation insufficient 时，页面显示 blockedReasons 和下一步。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1050" y="150" width="450" height="220" as="geometry" />
        </mxCell>
        <mxCell id="p7-audit" value="审计路径&#xa;&#xa;任务中心 -&gt; Operation -&gt; artifactRefs -&gt; 输入定义、数据覆盖、曲线指标、benchmark、前端截图、trade gate contract。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="250" y="510" width="430" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p7-prd" value="PRD 规格检视&#xa;&#xa;每个子阶段结束后检查：功能是否覆盖目标体验、测试是否覆盖功能点、文档概念是否一致、是否存在虚假验收风险。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="760" y="510" width="430" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p7-human" value="人类只处理高风险流程&#xa;&#xa;正式交易动作、正式 provider 凭证、人工复核结论、AUTO_TRADE 授权必须人工确认。自动化只能做前置和阻断审计。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1270" y="510" width="430" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p7-e1" value="产物" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p7-path1" target="p7-audit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7-e2" value="证据" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p7-path2" target="p7-audit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7-e3" value="打回" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p7-path3" target="p7-prd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7-e4" value="规格检视" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p7-audit" target="p7-prd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7-e5" value="高风险确认" style="endArrow=block;html=1;strokeColor=#DC2626;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p7-prd" target="p7-human">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
