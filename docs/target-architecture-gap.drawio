<mxfile host="Electron" agent="Codex" pages="7">
  <diagram id="01 目标体验与用户路径" name="01 目标体验与用户路径">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="01-2" value="FAMS 当前阶段目标体验：研究筛选、组合回测、人工计划草案、审计追溯&#xa;当前状态：formalTradingUnlocked=false / autoTradeUnlocked=false / orderCreateAllowed=false" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#1f2937;fontColor=#ffffff;fontStyle=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1840" height="70" as="geometry" />
        </mxCell>
        <mxCell id="01-3" value="颜色说明&#xa;灰色=已实现基础&#xa;黄色=需修改/状态不达标&#xa;橘黄=需新增正式 release 能力&#xa;红色=交易硬边界&#xa;蓝色=用户路径&#xa;绿色=出门证据" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#999999;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="290" height="250" as="geometry" />
        </mxCell>
        <mxCell id="01-4" value="路径 A：红利低波策略&#xa;页面：DividendLowVol.tsx&#xa;用户查看候选、Top3、买入观察区间、卖出观察区间、rolling 策略、数据来源和 priceAudit。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="380" y="130" width="430" height="170" as="geometry" />
        </mxCell>
        <mxCell id="01-5" value="路径 B：组合策略回测&#xa;页面：Backtest.tsx&#xa;用户选择红利低波篮子、当前持仓、永久组合、全天候组合或自定义组合，设置起止时间并查看收益曲线。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="860" y="130" width="450" height="170" as="geometry" />
        </mxCell>
        <mxCell id="01-6" value="路径 C：人工计划草案&#xa;服务：portfolioBacktestReviewService&#xa;输出 currentWeight、researchTargetWeight、formalTargetWeight=0、失效条件、复核 checklist。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1360" y="130" width="480" height="170" as="geometry" />
        </mxCell>
        <mxCell id="01-7" value="任务与审计追溯&#xa;页面：Operations.tsx&#xa;用户追踪 Operation、artifactRefs、acceptance-report.html、SUMMARY_FOR_GPT.md 和 release gate 产物。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="380" y="360" width="430" height="170" as="geometry" />
        </mxCell>
        <mxCell id="01-8" value="用户可见结果&#xa;1. 可以研究和比较策略&#xa;2. 可以生成 PLAN_DRAFT / MANUAL_TRADE_DRAFT&#xa;3. 可以看到为什么仍不能正式交易&#xa;4. 可以复现输入、模型、回测和 gate 结论" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="860" y="360" width="450" height="170" as="geometry" />
        </mxCell>
        <mxCell id="01-9" value="禁止动作硬边界&#xa;prohibitedActions=ADD / REDUCE / ORDER_CREATE / AUTO_TRADE&#xa;无下单按钮、无自动再平衡入口、无正式买入/卖出指令。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#f4cccc;strokeColor=#cc0000;fontColor=#990000;" vertex="1" parent="1">
          <mxGeometry x="1360" y="360" width="480" height="170" as="geometry" />
        </mxCell>
        <mxCell id="01-10" value="出门体验验收&#xa;用户能完成：选择策略 -&gt; 设置参数 -&gt; 查看曲线/指标 -&gt; 查看数据等级/模型有效性 -&gt; 生成草案 -&gt; 查看 release blockers。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="380" y="610" width="1460" height="150" as="geometry" />
        </mxCell>
        <mxCell id="01-e11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6b7280;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="01-4" target="01-5">
