  <diagram id="05 模型验证与 Release Gate" name="05 模型验证与 Release Gate">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="05-2" value="模型验证与 Release Gate：长周期回测必须经过 OOS、walk-forward、参数和分组稳定性" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#1f2937;fontColor=#ffffff;fontStyle=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1840" height="70" as="geometry" />
        </mxCell>
        <mxCell id="05-3" value="已具备评审材料&#xa;portfolioBacktestFormalReviewReady=true&#xa;manualDraftReady=true&#xa;paperSandboxReviewReady=true&#xa;interactiveStrategyBacktestReady=true&#xa;longHorizonRealDataBacktestReady=true" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="70" y="150" width="360" height="220" as="geometry" />
        </mxCell>
        <mxCell id="05-4" value="OOS 样本外验证&#xa;训练期与样本外收益、胜率、尾部亏损必须对比。&#xa;样本外收益或超额收益为负时，不得 formal passed。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="500" y="150" width="380" height="220" as="geometry" />
        </mxCell>
        <mxCell id="05-5" value="Walk-forward 验证&#xa;至少 6 个窗口。&#xa;通过窗口比例不足或单窗口通过时，保持 warning/insufficient。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="950" y="150" width="380" height="220" as="geometry" />
        </mxCell>
        <mxCell id="05-6" value="参数敏感性&#xa;月度/季度再平衡、费用、滑点、分红现金/再投资等邻域重放。&#xa;不得用单点参数通过替代稳定性。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1400" y="150" width="390" height="220" as="geometry" />
        </mxCell>
        <mxCell id="05-7" value="分组稳定性&#xa;行业、市场状态、流动性、市值分组。&#xa;分组样本不足时保持 insufficient，不升级 passed。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="70" y="460" width="360" height="220" as="geometry" />
        </mxCell>
        <mxCell id="05-8" value="人工签核&#xa;manualSignoffAudit.status=missing&#xa;数据、模型、风控、合规、最终 release 缺一不可。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="500" y="460" width="380" height="220" as="geometry" />
        </mxCell>
        <mxCell id="05-9" value="Release Gate&#xa;releaseGateAudit.status=blocked&#xa;任一 gate 未通过时：formalTradingUnlocked=false / canCreateOrder=false / orderCreateAllowed=false。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#f4cccc;strokeColor=#cc0000;fontColor=#990000;" vertex="1" parent="1">
          <mxGeometry x="950" y="460" width="380" height="220" as="geometry" />
        </mxCell>
        <mxCell id="05-10" value="最终结论&#xa;当前已完成长周期真实数据 replay 与 formal-review-ready。&#xa;仍未完成：formal validation passed / manual signoff / release gate。&#xa;可以声明：longHorizonRealDataBacktestReady=true / formal-review-ready / manual-draft-ready。&#xa;不能声明：formal-trading-ready / order-create-ready / auto-trade-ready。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#f4cccc;strokeColor=#cc0000;fontColor=#990000;" vertex="1" parent="1">
          <mxGeometry x="1400" y="460" width="390" height="220" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="06 开发及验收计划" name="06 开发及验收计划">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="06-2" value="开发及验收计划：FTR-1 到 FTR-6，完成后用户能完成正式交易 release 前置评审路径" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#1f2937;fontColor=#ffffff;fontStyle=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1840" height="70" as="geometry" />
        </mxCell>
        <mxCell id="06-3" value="Done-D1 长周期真实数据覆盖&#xa;实现：1年/3年/5年/custom replay 已使用免费真实行情补齐核心样本&#xa;产物：19_long_horizon_data_coverage_audit.json / 20_multi_period_backtest_result.json&#xa;验收：1年/3年/5年覆盖率均 &gt;=80%，当前 96.43%/95.90%/95.71%&#xa;用户效果：可比较 7 个策略的长周期曲线与指标。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="560" height="230" as="geometry" />
        </mxCell>
        <mxCell id="06-4" value="FTR-1 正式数据治理&#xa;实现：FormalDataProviderService / 字段级 sourceProvider、asOfDate、freshness、coverage、crossCheck、evidenceRefs&#xa;产物：15_data_governance_audit.json&#xa;验收：免费源、proxy、手工补录不得标为 official_authorized&#xa;用户效果：能看到每个关键字段来自哪里、是否新鲜、是否阻断 release。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="680" y="140" width="560" height="230" as="geometry" />
        </mxCell>
        <mxCell id="06-5" value="FTR-2 可信 Benchmark 与分红总回报&#xa;实现：PortfolioBenchmarkService、dividendContribution、ex-dividend adjustment、benchmarkQualification&#xa;产物：16_benchmark_qualification_audit.json / dividend_total_return_audit.json&#xa;验收：free-source 可 formal-review-ready，proxy 不得 formal passed，官方/可信 total-return 缺失仍阻断 release&#xa;用户效果：能区分价格收益、分红收益、benchmark 差异和 benchmark 资格。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1300" y="140" width="560" height="230" as="geometry" />
        </mxCell>
        <mxCell id="06-6" value="FTR-3 Formal validation&#xa;实现：OOS、walk-forward、参数敏感性、行业/市场/流动性分组稳定性、failure taxonomy&#xa;产物：17_formal_validation_audit.json&#xa;验收：任一 warning/insufficient/failed 均阻断 release；单窗口或单点参数不得 passed&#xa;用户效果：知道策略是否跨窗口、跨参数、跨分组稳定。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="60" y="430" width="560" height="230" as="geometry" />
        </mxCell>
        <mxCell id="06-7" value="FTR-4 人工签核与可视化验收&#xa;实现：ManualSignoffService、data/model/risk/compliance/final_release 多角色签核、自动化浏览器验收截图&#xa;产物：18_manual_signoff_audit.json / acceptance-report.html&#xa;验收：缺任一角色签核或用户路径截图失败，release blocked&#xa;用户效果：人类能复核策略、数据、风险、页面路径和阻断项。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="680" y="430" width="560" height="230" as="geometry" />
        </mxCell>
        <mxCell id="06-8" value="FTR-5/FTR-6 执行隔离与 Release Gate&#xa;实现：paperOrderIntents、executionIsolationAudit、releaseGateAudit、SUMMARY_FOR_GPT 聚合&#xa;产物：13_execution_isolation_audit.json / 14_release_gate_audit.json&#xa;验收：productionAdapterEnabled=false 时不能下单；缺数据、benchmark、validation、签核任一项时 blocked&#xa;用户效果：看到正式交易 release 还差什么，且不会误触实盘订单。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#f4cccc;strokeColor=#cc0000;fontColor=#990000;" vertex="1" parent="1">
          <mxGeometry x="1300" y="430" width="560" height="230" as="geometry" />
        </mxCell>
        <mxCell id="06-9" value="命令验收&#xa;node docs/read-drawio.mjs docs/target-architecture-gap.drawio&#xa;rg 状态词典与 hard boundary&#xa;git diff --check -- docs&#xa;后续代码阶段：test:portfolio-backtest-api-contract / test:portfolio-backtest-formal-review-readiness / frontend build / HTML 可视化验收" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#999999;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="60" y="730" width="1800" height="180" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="07 里程碑与出门条件" name="07 里程碑与出门条件">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="07-2" value="里程碑、出门条件与审计路径：明确能声明什么，不能声明什么" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#1f2937;fontColor=#ffffff;fontStyle=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1840" height="70" as="geometry" />
        </mxCell>
        <mxCell id="07-3" value="M1 文档出门&#xa;PRD、目标架构、drawio、计划、审计报告一致。&#xa;drawioPageCount=7 且 &lt;=8。&#xa;每个关键节点绑定真实实体。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="70" y="140" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-4" value="M2 长周期数据出门：已完成&#xa;1年/3年/5年/自定义区间覆盖报告完整。&#xa;当前覆盖：96.43% / 95.90% / 95.71% / 94.49%。&#xa;可声明 longHorizonRealDataBacktestReady=true，但仍不等于正式交易 release。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="520" y="140" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-5" value="M3 数据治理与 Benchmark 出门&#xa;正式 provider 字段级证据完整。&#xa;官方或可信 total-return benchmark 可审计。&#xa;free source / proxy 仍只用于 research 或 fallback。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="970" y="140" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-6" value="M4 模型验证出门&#xa;OOS / walk-forward / 参数敏感性 / 分组稳定性均 passed。&#xa;17_formal_validation_audit.json 不再 warning。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1420" y="140" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-7" value="M5 人工签核出门&#xa;数据、模型、风控、合规、最终 release 全部签核。&#xa;18_manual_signoff_audit.json 不再 missing。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="70" y="420" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-8" value="M6 执行隔离出门&#xa;paper/sandbox 与 production order 隔离已可评审。&#xa;13_execution_isolation_audit.json 通过。&#xa;production adapter 仍保持 disabled，不能创建订单。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="520" y="420" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-9" value="M7 Release 评审出门&#xa;14_release_gate_audit.json 汇总全部 gate。&#xa;只有所有 gate 通过且人工批准，才可讨论正式交易 release；AUTO_TRADE 仍需独立项目。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#f4cccc;strokeColor=#cc0000;fontColor=#990000;" vertex="1" parent="1">
          <mxGeometry x="970" y="420" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-10" value="当前可声明&#xa;researchReady=true&#xa;portfolioBacktestFormalReviewReady=true&#xa;manualTradePlanDraftReviewReady=true&#xa;paperSandboxReviewReady=true&#xa;longHorizonRealDataBacktestReady=true" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1420" y="420" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="07-11" value="当前不能声明&#xa;formalTradingUnlocked 不得为 true&#xa;autoTradeUnlocked 不得为 true&#xa;orderCreateAllowed 不得为 true&#xa;canCreateOrder 不得为 true&#xa;formal ADD / REDUCE released 不得出现&#xa;auto rebalance ready 不得出现" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#f4cccc;strokeColor=#cc0000;fontColor=#990000;" vertex="1" parent="1">
          <mxGeometry x="70" y="700" width="390" height="220" as="geometry" />
        </mxCell>
        <mxCell id="07-12" value="必须审计的文档路径&#xa;docs/FORMAL_TRADING_RELEASE_DEVELOPMENT_ACCEPTANCE_PLAN.md&#xa;docs/FORMAL_TRADING_RELEASE_DOC_AUDIT.md&#xa;docs/TARGET_ARCHITECTURE_GAP.md&#xa;docs/ARCHITECTURE_CURRENT_TARGET.md&#xa;docs/DIVIDEND_LOW_VOL_PRD.md&#xa;docs/PORTFOLIO_STRATEGY_BACKTEST_PLAN.md&#xa;docs/target-architecture-gap.drawio&#xa;docs/read-drawio-output.txt&#xa;backend/data/gpt-audit/interactive-strategy-backtest/latest/SUMMARY_FOR_GPT.md" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#999999;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="520" y="700" width="840" height="220" as="geometry" />
        </mxCell>
        <mxCell id="07-13" value="风险与备选路线&#xa;路线A：免费源优先，严格 evidence/freshness，适合 research/formal-review-ready。&#xa;路线B：正式 provider 优先，可信度高但依赖 token、权限和成本。&#xa;路线C：免费源 + 本地缓存 + proxy 明示 + 后续 provider 升级（推荐）。&#xa;任一路线都不得把 proxy benchmark 或签核缺失包装成 formal trading release。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=13;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1420" y="700" width="390" height="220" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
