  <diagram id="p5" name="5 开发计划">
    <mxGraphModel dx="1920" dy="1080" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p5-title" value="开发及验收计划：完成后用户可交互式比较策略并生成人工计划草案" style="text;html=1;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="120" y="35" width="1680" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p5-0" value="PBT-0 Runtime Health（已完成）&#xa;&#xa;统一 /health、SQLite health、组合回测 API、红利低波 audit 和交互式回测审计包。当前 runtimeHealth=healthy。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="150" width="350" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p5-8" value="PBT-8 ETF 代理行情（已完成）&#xa;&#xa;510300 / 511010 / 511260 / 518880 / 159985 代理行情覆盖 ready，可支撑永久组合和全天候组合 completed。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="470" y="150" width="350" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p5-9" value="PBT-9 Benchmark + 分红总回报（已完成正式评审前置）&#xa;&#xa;已输出 price-only、分红贡献、资本利得、成本拖累、benchmark、超额收益；免费源 total-return benchmark 可支撑 formal review，官方授权 benchmark 后续增强。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="870" y="150" width="350" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p5-10" value="PBT-10 Operation + 前端验收（已完成）&#xa;&#xa;组合回测 Operation 化；任务中心 artifact；无头浏览器已覆盖加载、配置、运行、曲线、指标、非交易提示。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1270" y="150" width="350" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p5-11" value="PBT-11 组合回测正式评审前置（已达成，交易未解锁）&#xa;&#xa;审计包已记录 portfolioBacktestFormalReviewReady=true；正式交易仍需官方 benchmark、模型有效性验证和人工复核。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="520" width="430" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p5-doc" value="下一阶段正式交易级前置计划&#xa;&#xa;FT-1 数据等级；FT-2 模型有效性；FT-3 人工草案；FT-4 前端评审工作台；FT-5 审计包升级；FT-6 解锁闸门。每项完成后做 PRD 规格检视和 E2E 验收。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="810" y="520" width="430" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p5-out" value="完成后目标体验&#xa;&#xa;用户可比较策略、查看数据等级和模型有效性、打开 artifact、生成人工计划草案；系统显示正式交易解锁 blocker，仍不创建订单。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
