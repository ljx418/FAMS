<mxfile host="Electron" agent="Codex" pages="8">
  <diagram id="01 目标体验与用户路径" name="01 目标体验与用户路径">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="01-title" value="FAMS UX 优化阶段目标体验&#xa;普通用户 30 秒内看懂：当前结论、为什么、可信度、下一步；交易动作继续锁定" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#1f2937;fontColor=#ffffff;fontStyle=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1840" height="70" as="geometry" />
        </mxCell>
        <mxCell id="01-legend" value="颜色说明&#xa;灰=已实现基础&#xa;黄=需修改/体验复杂&#xa;橘=待新增能力&#xa;紫=体验解释层&#xa;红=交易硬边界&#xa;蓝=用户路径&#xa;绿=出门体验" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#ffffff;strokeColor=#999999;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="50" y="130" width="280" height="250" as="geometry" />
        </mxCell>
        <mxCell id="01-start" value="今日从这里开始&#xa;页面：Dashboard.tsx / AppLayout.tsx&#xa;用户先看到：红利低波、策略回测、任务审计三个入口，以及“当前只能研究观察”的提示。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="380" y="130" width="430" height="150" as="geometry" />
        </mxCell>
        <mxCell id="01-dlv" value="路径 A：红利低波策略&#xa;页面：DividendLowVol.tsx&#xa;普通模式：Top 候选结论卡、观察区间、数据可信、下一步按钮。&#xa;专业模式：完整分数、证据、validation、audit artifact。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="860" y="130" width="450" height="190" as="geometry" />
        </mxCell>
        <mxCell id="01-backtest" value="路径 B：策略回测&#xa;页面：Backtest.tsx&#xa;普通模式：收益最高、回撤最低、数据最可信、阻断原因。&#xa;专业模式：曲线、指标、benchmark、validation matrix。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1360" y="130" width="480" height="190" as="geometry" />
        </mxCell>
        <mxCell id="01-draft" value="路径 C：人工计划草案&#xa;服务：portfolioBacktestReviewService&#xa;只输出 PLAN_DRAFT / MANUAL_TRADE_DRAFT。formalTargetWeight=0，canCreateOrder=false。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="380" y="390" width="430" height="170" as="geometry" />
        </mxCell>
        <mxCell id="01-ops" value="路径 D：任务与审计追溯&#xa;页面：Operations.tsx&#xa;每个任务解释：做了什么、成功/失败、产物在哪里、能否用于交易。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="860" y="390" width="450" height="170" as="geometry" />
        </mxCell>
        <mxCell id="01-boundary" value="交易硬边界&#xa;prohibitedActions=ADD / REDUCE / ORDER_CREATE / AUTO_TRADE&#xa;无下单按钮、无自动再平衡入口、无正式买入/卖出文案。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#f4cccc;strokeColor=#cc0000;fontColor=#990000;" vertex="1" parent="1">
          <mxGeometry x="1360" y="390" width="480" height="170" as="geometry" />
        </mxCell>
        <mxCell id="01-outcome" value="本阶段出门体验&#xa;用户不用理解 evidenceAdjustedScore、OOS、benchmark proxy，也能判断：是否值得继续观察、为什么不能正式交易、需要补什么证据。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="380" y="650" width="1460" height="150" as="geometry" />
        </mxCell>
        <mxCell id="01-e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6b7280;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="01-start" target="01-dlv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="01-e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6b7280;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="01-dlv" target="01-backtest">
          <mxGeometry relative="1" as="geometry" />
