<mxfile host="Electron" agent="draw.io" pages="7">
  <diagram id="p1" name="1 目标体验">
    <mxGraphModel dx="1920" dy="1080" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p1-title" value="本阶段目标体验：交互式策略回测 + 正式交易级前置，不自动交易" style="text;html=1;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="120" y="35" width="1680" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p1-a" value="入口体验&#xa;&#xa;用户从左侧进入策略回测或红利低波页面。页面顶部显示研究模式、数据状态、禁止动作和最新审计状态。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p1-b" value="选择策略&#xa;&#xa;红利低波篮子、当前持仓、永久组合、全天候组合、本地真实样本组合、自定义权重组合。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="430" y="160" width="310" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p1-c" value="设置参数&#xa;&#xa;起止时间、初始资金、再平衡频率、分红处理、手续费、滑点、benchmark。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="790" y="160" width="310" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p1-d" value="查看结果&#xa;&#xa;收益曲线、回撤曲线、指标表、benchmarkReturn、excessReturn、dividendContribution、dataCoverage、blockedReasons。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1150" y="160" width="340" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p1-e" value="追溯证据&#xa;&#xa;打开每个策略的输入定义、行情覆盖、分红覆盖、benchmark 状态、交易约束、evidenceRefs 和 Operation artifact。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="360" y="500" width="360" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p1-f" value="人工计划草案&#xa;&#xa;满足 gate 时只生成 manual draft / watchlist / pretrade check。formalTargetWeight=0，canCreateOrder=false。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="500" width="360" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p1-g" value="硬边界&#xa;&#xa;禁止正式 ADD / REDUCE / ORDER_CREATE / AUTO_TRADE。研究回测不能包装成正式交易验证。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1240" y="500" width="360" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p1-e1" value="选择" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p1-a" target="p1-b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-e2" value="配置" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p1-b" target="p1-c">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-e3" value="运行" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p1-c" target="p1-d">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-e4" value="查看证据" style="endArrow=block;html=1;strokeColor=#D17A22;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p1-d" target="p1-e">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-e5" value="人工复核" style="endArrow=block;html=1;strokeColor=#D17A22;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p1-e" target="p1-f">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-e6" value="交易保护" style="endArrow=block;html=1;strokeColor=#DC2626;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p1-f" target="p1-g">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
