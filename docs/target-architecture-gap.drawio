  <diagram id="p6" name="6 验收门槛与出门条件">
    <mxGraphModel dx="1920" dy="1080" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p6-title" value="验收门槛与出门条件：用户体验可见、数据证据可审计、交易动作不误放" style="text;html=1;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="120" y="35" width="1680" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p6-doc" value="文档验收&#xa;&#xa;drawio 页数 &lt;=8；中文书写；可解析；PRD、目标架构、里程碑、验收门槛、出门条件一致。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="350" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p6-ux" value="用户体验验收&#xa;&#xa;能选择多策略、设置时间区间和参数、运行回测、查看多曲线、指标、缺口、benchmark 和证据。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="480" y="150" width="350" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p6-data" value="数据验收&#xa;&#xa;runtime health gate 一致；ETF 代理 &gt;=250 交易日；至少一个宽基 benchmark；分红贡献不恒为 null；stale/unknown/mismatch 显示阻断。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="880" y="150" width="390" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p6-val" value="验证验收&#xa;&#xa;当前组合回测 formal-review-ready passed；OOS、walk-forward、参数敏感性、行业/市场/流动性分组仍是正式交易解锁前置，不由免费源 benchmark 自动解锁。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1320" y="150" width="390" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p6-cmd" value="机器验收命令&#xa;&#xa;read-drawio；backend tsc；portfolio-backtest tests；dividend-low-vol tests；production-readiness；trade-action-readiness；frontend build。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="260" y="540" width="410" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p6-pass" value="本阶段可出门&#xa;&#xa;interactive_strategy_backtest_ready&#xa;research_grade_strategy_comparison_ready&#xa;portfolio_backtest_formal_review_ready&#xa;manual_trade_draft_ready&#xa;formal_trading_locked&#xa;auto_trade_locked" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="760" y="540" width="410" height="260" as="geometry" />
        </mxCell>
        <mxCell id="p6-fail" value="本阶段不可出门&#xa;&#xa;formal_trade_action_ready&#xa;formal_add_reduce_unlocked&#xa;auto_rebalance_ready&#xa;auto_trade_ready&#xa;免费源 100% 最新承诺&#xa;免费源 benchmark 等同官方授权 benchmark" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=15;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1260" y="540" width="410" height="260" as="geometry" />
        </mxCell>
        <mxCell id="p6-e1" value="规格到体验" style="endArrow=block;html=1;strokeColor=#6B7280;strokeWidth=2;fontSize=12;" edge="1" parent="1" source="p6-doc" target="p6-ux">
          <mxGeometry relative="1" as="geometry" />
