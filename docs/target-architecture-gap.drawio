          <mxGeometry x="250" y="430" width="440" height="180" as="geometry" />
        </mxCell>
        <mxCell id="05-blocker" value="阻断原因&#xa;research_proxy / insufficient / validation warning / manual signoff missing / releaseGate blocked。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#f4cccc;strokeColor=#cc0000;fontColor=#990000;" vertex="1" parent="1">
          <mxGeometry x="760" y="430" width="440" height="180" as="geometry" />
        </mxCell>
        <mxCell id="05-draft" value="草案与审计&#xa;生成 manualPlanDraft 或查看 blockedReasons；Operations 追踪 artifactRefs。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1270" y="430" width="440" height="180" as="geometry" />
