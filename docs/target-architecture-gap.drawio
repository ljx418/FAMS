        <mxCell id="p4-d5" value="D5 人工草案路径&#xa;&#xa;candidate -&gt; draft -&gt; acceptance -&gt; watchlist -&gt; pretrade check&#xa;formalTargetWeight=0&#xa;canCreateOrder=false" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1480" y="170" width="300" height="180" as="geometry" />
        </mxCell>
        <mxCell id="p4-d6" value="D6 正式交易评审前置&#xa;&#xa;正式 provider&#xa;官方 / 免费宽基 total-return benchmark&#xa;ETF 代理行情覆盖&#xa;完整交易约束&#xa;formal validation 全通过&#xa;人工复核通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=15;fontStyle=1;spacing=10;" vertex="1" parent="1">
