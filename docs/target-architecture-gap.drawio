  <diagram id="p6" name="6 开发及验收计划">
    <mxGraphModel dx="1920" dy="1080" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p6-title" value="开发及验收计划：目标、实现位置、产物、用户效果" style="text;html=1;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="80" y="25" width="1760" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p6-subtitle" value="本页回答“开发怎么做、怎么验收”：FT-1 到 FT-6 每项都映射到服务、字段、审计文件和用户可见结果。" style="text;html=1;fontSize=16;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="100" y="90" width="1320" height="45" as="geometry" />
        </mxCell>
        <mxCell id="p6-legend" value="颜色规则&#xa;灰色=已实现&#xa;黄色=需修改&#xa;橘黄=需新增&#xa;红色=交易硬边界&#xa;蓝/绿=目标状态或出门证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=13;spacing=10;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1510" y="90" width="320" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p6-1" value="FT-1 数据等级&#xa;实现：PortfolioBacktestEngine + Routes + Backtest.tsx&#xa;字段：dataGrade / dataGradeAudit&#xa;产物：09_data_grade_audit.json&#xa;用户效果：看懂官方/免费/代理/不足" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="520" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p6-2" value="FT-2 模型有效性&#xa;实现：组合 OOS / walk-forward / sensitivity / group stability&#xa;字段：modelEffectivenessStatus&#xa;产物：10_model_effectiveness_audit.json&#xa;用户效果：知道策略是否只是历史拟合" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="150" width="520" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p6-3" value="FT-3 人工草案&#xa;实现：portfolioBacktestReviewService + manualPlanDraft + trade gate&#xa;字段：formalTargetWeight=0、blockedReasons、checklist&#xa;产物：11_manual_plan_draft_audit.json&#xa;用户效果：只拿到复核草案，不会下单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1320" y="150" width="520" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p6-4" value="FT-4 前端评审工作台&#xa;实现：/backtest 正式评审摘要、策略卡、阻断标签&#xa;验收：portfolio-backtest-frontend-runtime&#xa;用户效果：一屏看清曲线、数据、模型、gate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="520" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p6-5" value="FT-5 审计包升级&#xa;实现：run:interactive-strategy-backtest-audit-package&#xa;产物：SUMMARY_FOR_GPT.md + 09-12 JSON&#xa;用户效果：ChatGPT/人工能复审，不靠口头汇报" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="420" width="520" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p6-6" value="FT-6 解锁清单&#xa;实现：formalTradingUnlockChecklist&#xa;规则：人工未确认时 blocked&#xa;产物：12_formal_trading_unlock_blockers.json&#xa;用户效果：明确为什么仍不能正式交易" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1320" y="420" width="520" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p6-test" value="统一验收命令&#xa;backend: tsc、portfolio-backtest-formal-review-readiness、api-contract、frontend-runtime、trade-action-readiness、fivd-r-trade-gate-contract、audit-package、full-system-e2e&#xa;frontend: npm run build" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="250" y="740" width="1420" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p7" name="7 里程碑出门与审计">
    <mxGraphModel dx="1920" dy="1080" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p7-title" value="里程碑、出门条件与审计路径" style="text;html=1;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="80" y="25" width="1760" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p7-subtitle" value="本页回答“什么时候算完成、什么不能说完成”：阶段出门只到正式交易前置评审，不到正式交易 release。" style="text;html=1;fontSize=16;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="100" y="90" width="1320" height="45" as="geometry" />
        </mxCell>
        <mxCell id="p7-legend" value="颜色规则&#xa;灰色=已实现&#xa;黄色=需修改&#xa;橘黄=需新增&#xa;红色=交易硬边界&#xa;蓝/绿=目标状态或出门证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=13;spacing=10;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1510" y="90" width="320" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p7-a" value="本阶段可声明&#xa;interactive_strategy_backtest_ready&#xa;research_grade_strategy_comparison_ready&#xa;portfolio_backtest_formal_review_ready&#xa;manual_trade_draft_ready&#xa;formal_trading_locked&#xa;auto_trade_locked" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="90" y="160" width="430" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p7-b" value="本阶段不能声明&#xa;formal_trade_action_ready&#xa;formal_add_reduce_unlocked&#xa;order_create_allowed&#xa;auto_rebalance_ready&#xa;auto_trade_ready&#xa;official_benchmark_certified" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="580" y="160" width="430" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p7-c" value="下一阶段 blocker&#xa;官方授权 benchmark&#xa;正式 provider 与授权&#xa;完整交易约束&#xa;人工复核记录持久化&#xa;合规/风控签核&#xa;订单执行系统隔离评审" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1070" y="160" width="430" height="240" as="geometry" />
        </mxCell>
        <mxCell id="p7-d" value="审计材料路径&#xa;docs/target-architecture-gap.drawio&#xa;docs/TARGET_ARCHITECTURE_GAP.md&#xa;docs/PORTFOLIO_STRATEGY_BACKTEST_FORMAL_TRADING_STAGE_PLAN.md&#xa;backend/data/gpt-audit/.../SUMMARY_FOR_GPT.md&#xa;acceptance-report.html" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="90" y="520" width="580" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p7-e" value="人工/ChatGPT 审计重点&#xa;1 数据是否可信&#xa;2 模型是否有效&#xa;3 草案是否不越权&#xa;4 前端是否不误导&#xa;5 blockers 是否完整&#xa;6 是否仍禁止 AUTO_TRADE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="520" width="500" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p7-f" value="最终边界&#xa;正式交易解锁不是自动化验收结果&#xa;必须由独立人工确认和后续正式数据/执行约束评审完成&#xa;本图不得被解释为交易授权" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1310" y="520" width="500" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p7-g" value="完成判定&#xa;文档清楚 + 图可读 + E2E 报告通过 + 审计包可复核 + 前端路径可走通 + 交易仍锁定" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=14;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="350" y="850" width="1220" height="110" as="geometry" />
        </mxCell>
