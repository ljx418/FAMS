<mxfile host="Electron" agent="draw.io" pages="7">
  <diagram id="page-target-experience" name="1 目标体验">
    <mxGraphModel dx="1920" dy="1080" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p1-title" value="红利低波策略目标体验：研究、观察、人工计划草案，不是自动交易" style="text;html=1;fontSize=30;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="210" y="40" width="1500" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p1-subtitle" value="用户能快速筛选高分红低波行业龙头，理解数据来源、价格新鲜度、买卖观察区间和交易 gate；系统始终禁止 ADD / REDUCE / AUTO_TRADE。" style="text;html=1;fontSize=16;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#4B5563;" vertex="1" parent="1">
          <mxGeometry x="180" y="95" width="1560" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p1-entry" value="1 进入策略页面&#xa;&#xa;左侧菜单：红利低波策略&#xa;显示研究模式 banner&#xa;显示禁止动作和最新数据状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=16;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p1-candidates" value="2 筛选候选池&#xa;&#xa;全 A 候选&#xa;行业 / 等级 / 综合分 / 股息率 / 低波分 / 质量分 / 估值分筛选排序&#xa;所有字段必须有值或状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5E7EB;strokeColor=#6B7280;fontSize=16;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="470" y="200" width="320" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p1-evidence" value="3 理解证据&#xa;&#xa;入选理由&#xa;剔除原因分类&#xa;行业龙头证据&#xa;分红事实集&#xa;风险标记和 evidenceRefs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=16;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="860" y="200" width="320" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p1-zones" value="4 查看观察区间&#xa;&#xa;买入观察区间&#xa;卖出观察区间&#xa;止损 / 失效条件&#xa;priceAudit：交易日、来源、新鲜度、错配检查" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=16;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1250" y="200" width="330" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p1-draft" value="5 生成人工草案&#xa;&#xa;manual draft&#xa;manual acceptance&#xa;watchlist&#xa;pretrade check&#xa;formalTargetWeight=0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=16;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="520" width="330" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p1-audit" value="6 审计追溯&#xa;&#xa;Operation 状态&#xa;daily scan 调度&#xa;审计包&#xa;validation retest&#xa;trade gate contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=16;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="780" y="520" width="330" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p1-gate" value="硬边界&#xa;&#xa;免费源不能保证 100% 每日最新&#xa;stale / unknown / price_zone_mismatch =&gt; 需刷新后重算&#xa;validation insufficient =&gt; 保持研究和草案&#xa;禁止 ADD / REDUCE / AUTO_TRADE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=16;fontStyle=1;spacing=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1290" y="520" width="390" height="210" as="geometry" />
        </mxCell>
        <mxCell id="p1-e1" value="使用路径" style="endArrow=block;html=1;strokeColor=#64748B;strokeWidth=2;" edge="1" parent="1" source="p1-entry" target="p1-candidates">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-e2" value="查看" style="endArrow=block;html=1;strokeColor=#64748B;strokeWidth=2;" edge="1" parent="1" source="p1-candidates" target="p1-evidence">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-e3" value="复核" style="endArrow=block;html=1;strokeColor=#64748B;strokeWidth=2;" edge="1" parent="1" source="p1-evidence" target="p1-zones">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-e4" value="只生成草案" style="endArrow=block;html=1;strokeColor=#D17A22;strokeWidth=2;" edge="1" parent="1" source="p1-zones" target="p1-draft">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-e5" value="产物追踪" style="endArrow=block;html=1;strokeColor=#D17A22;strokeWidth=2;" edge="1" parent="1" source="p1-draft" target="p1-audit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-e6" value="交易保护" style="endArrow=block;html=1;strokeColor=#DC2626;strokeWidth=2;" edge="1" parent="1" source="p1-audit" target="p1-gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
