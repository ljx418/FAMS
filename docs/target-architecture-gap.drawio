        <mxCell id="05-outcome" value="出门验收&#xa;用户 10 秒内知道：哪条策略更稳、哪条收益高、哪条数据不足，以及为什么仍不能交易。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="250" y="705" width="1460" height="130" as="geometry" />
