        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="05-title" value="组合回测用户路径：从曲线指标优先改为“策略对比摘要 + 数据缺口 + 阻断原因”" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#1f2937;fontColor=#ffffff;fontStyle=1;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1840" height="70" as="geometry" />
        </mxCell>
        <mxCell id="05-start" value="选择策略和时间&#xa;Backtest.tsx&#xa;推荐组合、红利低波篮子、当前持仓、自定义权重；支持 1年/3年/5年/自定义区间。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="70" y="150" width="420" height="170" as="geometry" />
        </mxCell>
        <mxCell id="05-run" value="运行回测&#xa;PortfolioBacktestEngine&#xa;输出收益曲线、回撤、benchmark、dividendContribution、dataGrade。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="540" y="150" width="420" height="170" as="geometry" />
        </mxCell>
        <mxCell id="05-summary" value="结果摘要卡&#xa;PortfolioBacktestSummaryCard.tsx&#xa;哪个收益最高、回撤最低、数据最可信、哪些仍被阻断。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="1010" y="150" width="420" height="170" as="geometry" />
        </mxCell>
        <mxCell id="05-explain" value="策略解释器&#xa;StrategyComparisonExplainer.tsx&#xa;把 Sharpe、Calmar、最大回撤、超额收益转成普通话解释。" style="rounded=1;whiteSpace=wrap;html=1;spacing=10;fontSize=12;align=left;verticalAlign=top;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#1f2937;" vertex="1" parent="1">
