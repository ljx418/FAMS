        <mxCell id="p5-validation" value="验证与审计验收&#xa;&#xa;effectivePathCount &gt;= 30&#xa;industryGroupCount &gt;= 3&#xa;walkForwardWindows &gt;= 6&#xa;proxy / local benchmark 不解锁 formal&#xa;组合回测审计包记录策略定义、曲线、benchmark、缺口和 gate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8D6;strokeColor=#D17A22;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1360" y="170" width="380" height="230" as="geometry" />
        </mxCell>
        <mxCell id="p5-commands" value="机器验收命令&#xa;&#xa;node docs/read-drawio.mjs docs/target-architecture-gap.drawio&#xa;backend: tsc / test:dividend-low-vol-api / rolling-backtest / test:portfolio-backtest-api-contract / test:portfolio-strategy-backtest / production-readiness / trade-action-readiness&#xa;frontend: npm run build" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;spacing=10;" vertex="1" parent="1">
