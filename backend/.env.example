# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL="file:./dev.db"

# Redis (Optional)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-key-change-in-production"

# Log
LOG_LEVEL=info

# External APIs (Optional - for production)
# YAHOO_FINANCE_API_KEY=""
# EASTMONEY_API_KEY=""

# Production readiness gates
# Keep DATABASE_URL on SQLite until the explicit PostgreSQL migration is reviewed.
# Shadow PostgreSQL is used only for staging/smoke/pressure verification.
# FAMS_POSTGRES_SHADOW_DATABASE_URL="postgresql://fams_shadow:change-me@127.0.0.1:5432/fams_shadow"
# FAMS_POSTGRES_SHADOW_TIMEOUT_MS=5000
# FAMS_POSTGRES_SHADOW_STATEMENT_TIMEOUT_MS=10000

# Optional formal A-share trading state provider.
# Free sources can produce analysis advice without this token; configure it for formal trading-state enhancement.
# FAMS_TUSHARE_TOKEN=""
# Optional dividend-low-vol formal provider ingestion controls.
# FAMS_DIVIDEND_LOW_VOL_PROVIDER_SYMBOLS="000001,600000"
# FAMS_DIVIDEND_LOW_VOL_PROVIDER_TRADE_DATE="20260605"
# FAMS_DIVIDEND_LOW_VOL_PROVIDER_PERIOD="20251231"
# Set to 1 to test contract/audit generation without calling Tushare.
# FAMS_DIVIDEND_LOW_VOL_PROVIDER_DRY_RUN=0

# Formal dividend-low-vol backtest promotion gates. Keep unset until the referenced datasets are genuinely ingested.
# FAMS_H30269_TOTAL_RETURN_BENCHMARK_READY=false
# FAMS_EX_DIVIDEND_TOTAL_RETURN_SERIES_READY=false
# FAMS_LIMIT_UP_DOWN_DAILY_STATE_READY=false
# FAMS_SUSPENSION_DAILY_STATE_READY=false

# Screener validation depth for full-A runs. Higher values are slower but reduce top-3 validation blind spots.
# FAMS_SCREENER_DEEP_VALIDATION_TOP_N=12

# CI/release gate. When set to 1, npm run test:production-readiness fails if analysis-advice readiness is red.
# FAMS_READINESS_STRICT=0
# Trade-action gate. When set to 1 or when using --strict-trade, readiness fails until validation evidence allows manual trade drafts.
# FAMS_TRADE_READINESS_STRICT=0
# FAMS_READINESS_SYMBOLS="000001,600000"
